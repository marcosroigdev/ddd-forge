{
    "name": "marcosroigdev/ddd-forge",
    "description": "Scaffolding tool for DDD & Hexagonal Architecture. Generate contexts, aggregates, repositories, and command handlers — with Symfony & Laravel support.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Marcos Roig",
            "email": "12345678+marcosroigdev@users.noreply.github.com",
            "homepage": "https://marcosroig.dev/",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "php",
        "ddd",
        "hexagonal",
        "architecture",
        "cqrs",
        "scaffolding",
        "cli",
        "generator",
        "symfony",
        "laravel",
        "code-generation",
        "clean-architecture"
    ],
    "require": {
        "php": ">=8.2",
        "symfony/console": "^7.3",
        "symfony/filesystem": "^7.3",
        "nette/php-generator": "^4.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.88"
    },
    "autoload": {
        "psr-4": {
            "DddForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DddForge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "forge": "bin/ddd-forge",
        "install-dev": "composer install",
        "test": "vendor/bin/phpunit -c phpunit.xml",
        "stan": "vendor/bin/phpstan analyse --no-progress",
        "lint": "vendor/bin/php-cs-fixer fix --diff --dry-run --verbose --quiet",
        "csfix": "vendor/bin/php-cs-fixer fix --diff --verbose --quiet",
        "qa": [
            "@test",
            "@stan",
            "@lint"
        ]
    },
    "bin": ["bin/ddd-forge"]
}
